<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAF2FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚖ BMI CALCULATOR"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A2BE2"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_blue"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Height (m)"
                android:textSize="14sp"
                android:textColor="#1A2BE2"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edtHeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. 1.65"
                android:textColor="#000000"
                android:textColorHint="#888888"
                android:inputType="numberDecimal"
                android:background="@drawable/input_box"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Weight (kg)"
                android:textSize="14sp"
                android:textColor="#1A2BE2"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edtWeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. 60"
                android:textColor="#000000"
                android:textColorHint="#888888"
                android:inputType="numberDecimal"
                android:background="@drawable/input_box"
                android:padding="12dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnCalculate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VIEW RESULT"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#4F6BED"
            android:layout_marginBottom="12dp" />

        <!-- Loading indicator -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <ProgressBar
                android:id="@+id/progressBmi"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:visibility="gone"
                android:indeterminateTint="#4F6BED" />

            <TextView
                android:id="@+id/txtLoadingBmi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  Getting AI advice..."
                android:textSize="14sp"
                android:textColor="#4F6BED"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_blue"
            android:padding="20dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/txtBmiValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textColor="#1A2BE2"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:id="@+id/txtCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textColor="#4F6BED"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DCE6FF"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/txtAdvice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#333333"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
