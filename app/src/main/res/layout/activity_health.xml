<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAF2FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💧 HEALTH TRACKER"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A2BE2"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_blue"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Water intake (glasses)"
                android:textSize="14sp"
                android:textColor="#1A2BE2"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edtWater"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. 8"
                android:textColor="#000000"
                android:textColorHint="#888888"
                android:inputType="number"
                android:background="@drawable/input_box"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sleep (hours)"
                android:textSize="14sp"
                android:textColor="#1A2BE2"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edtSleep"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. 7.5"
                android:textColor="#000000"
                android:textColorHint="#888888"
                android:inputType="numberDecimal"
                android:background="@drawable/input_box"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mood today"
                android:textSize="14sp"
                android:textColor="#1A2BE2"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edtMood"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. Happy, Tired, Stressed"
                android:textColor="#000000"
                android:textColorHint="#888888"
                android:background="@drawable/input_box"
                android:padding="12dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SAVE HEALTH LOG"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#4F6BED"
            android:layout_marginBottom="12dp" />

        <!-- Loading indicator -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <ProgressBar
                android:id="@+id/progressHealth"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:visibility="gone"
                android:indeterminateTint="#4F6BED" />

            <TextView
                android:id="@+id/txtLoadingHealth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  Generating AI insight..."
                android:textSize="14sp"
                android:textColor="#4F6BED"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/summaryCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_blue"
            android:padding="20dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today's Summary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A2BE2"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/txtSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#333333"
                android:lineSpacingExtra="6dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
