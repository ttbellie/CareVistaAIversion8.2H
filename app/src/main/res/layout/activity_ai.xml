<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAF2FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🤖 AI ASSISTANT"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A2BE2"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Powered by Llama 3.1 · Hybrid Mode"
            android:textSize="13sp"
            android:textColor="#4F6BED"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠ Your question is sent to Groq servers for AI processing."
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_blue"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ask a health question"
                android:textSize="14sp"
                android:textColor="#1A2BE2"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/edtQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. How can I sleep better?"
                android:textColor="#000000"
                android:textColorHint="#888888"
                android:minLines="3"
                android:gravity="top"
                android:background="@drawable/input_box"
                android:padding="12dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnAsk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ASK AI"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#4F6BED"
            android:layout_marginBottom="12dp" />

        <!-- Loading indicator -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:visibility="gone"
                android:indeterminateTint="#4F6BED" />

            <TextView
                android:id="@+id/txtLoading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  Llama 3.1 is thinking..."
                android:textSize="14sp"
                android:textColor="#4F6BED"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/responseCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_blue"
            android:padding="20dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Response"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A2BE2"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/txtResponse"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#333333"
                android:lineSpacingExtra="6dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
